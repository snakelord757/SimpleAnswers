<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/settingsScroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/paper"
    android:fitsSystemWindows="true"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <LinearLayout
            android:id="@+id/settingsTopBar"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="20dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/backButton"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:contentDescription="@string/back"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                app:cornerRadius="8dp"
                app:icon="@drawable/ic_arrow_back"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconTint="@color/ink" />

            <TextView
                android:id="@+id/settingsTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/settings"
                android:textColor="@color/ink"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="20dp"
            android:paddingTop="12dp"
            android:paddingEnd="20dp"
            android:text="@string/model_title"
            android:textColor="@color/ink"
            android:textSize="18sp"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/modelGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_answer_panel"
            android:orientation="vertical"
            android:padding="8dp">

            <RadioButton
                android:id="@+id/modelFlashButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:buttonTint="@color/sage"
                android:text="@string/model_flash"
                android:textColor="@color/ink"
                android:textSize="16sp" />

            <RadioButton
                android:id="@+id/modelProButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:buttonTint="@color/sage"
                android:text="@string/model_pro"
                android:textColor="@color/ink"
                android:textSize="16sp" />
        </RadioGroup>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="20dp"
            android:paddingTop="24dp"
            android:paddingEnd="20dp"
            android:text="@string/role_title"
            android:textColor="@color/ink"
            android:textSize="18sp"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/roleGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_answer_panel"
            android:orientation="vertical"
            android:padding="8dp">

            <RadioButton
                android:id="@+id/rolePhilosopherButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:buttonTint="@color/sage"
                android:text="@string/role_philosopher"
                android:textColor="@color/ink"
                android:textSize="16sp" />

            <RadioButton
                android:id="@+id/roleAssistantButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:buttonTint="@color/sage"
                android:text="@string/role_assistant"
                android:textColor="@color/ink"
                android:textSize="16sp" />

            <RadioButton
                android:id="@+id/roleWebAssistantButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:buttonTint="@color/sage"
                android:text="@string/role_web_assistant"
                android:textColor="@color/ink"
                android:textSize="16sp" />

            <RadioButton
                android:id="@+id/roleGorillaButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:buttonTint="@color/sage"
                android:text="@string/role_gorilla"
                android:textColor="@color/ink"
                android:textSize="16sp" />
        </RadioGroup>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/openWebModeButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            android:text="@string/open_web_mode"
            android:textColor="@android:color/white"
            app:backgroundTint="@color/clay"
            app:cornerRadius="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="20dp"
            android:paddingTop="24dp"
            android:paddingEnd="20dp"
            android:text="@string/limits_title"
            android:textColor="@color/ink"
            android:textSize="18sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/limitsPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_answer_panel"
            android:orientation="vertical"
            android:padding="12dp">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/maxTokensLayout"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/max_tokens_hint"
                app:boxBackgroundColor="@android:color/white"
                app:boxCornerRadiusBottomEnd="8dp"
                app:boxCornerRadiusBottomStart="8dp"
                app:boxCornerRadiusTopEnd="8dp"
                app:boxCornerRadiusTopStart="8dp"
                app:boxStrokeColor="@color/sage"
                app:hintTextColor="@color/input_hint_color">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/maxTokensEditText"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:inputType="number"
                    android:maxLines="1"
                    android:singleLine="true"
                    android:text="0"
                    android:textColor="@color/ink"
                    android:textColorHint="@color/ink"
                    android:textSize="16sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/stopSequenceLayout"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/stop_sequence_hint"
                app:boxBackgroundColor="@android:color/white"
                app:boxCornerRadiusBottomEnd="8dp"
                app:boxCornerRadiusBottomStart="8dp"
                app:boxCornerRadiusTopEnd="8dp"
                app:boxCornerRadiusTopStart="8dp"
                app:boxStrokeColor="@color/sage"
                app:endIconMode="clear_text"
                app:hintTextColor="@color/input_hint_color">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/stopSequenceEditText"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:inputType="text"
                    android:maxLines="1"
                    android:singleLine="true"
                    android:textColor="@color/ink"
                    android:textColorHint="@color/ink"
                    android:textSize="16sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/finishInstructionLayout"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/finish_instruction_hint"
                app:boxBackgroundColor="@android:color/white"
                app:boxCornerRadiusBottomEnd="8dp"
                app:boxCornerRadiusBottomStart="8dp"
                app:boxCornerRadiusTopEnd="8dp"
                app:boxCornerRadiusTopStart="8dp"
                app:boxStrokeColor="@color/sage"
                app:endIconMode="clear_text"
                app:hintTextColor="@color/input_hint_color">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/finishInstructionEditText"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:inputType="textCapSentences"
                    android:maxLines="1"
                    android:singleLine="true"
                    android:textColor="@color/ink"
                    android:textColorHint="@color/ink"
                    android:textSize="16sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/thinkingModeSwitch"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="18dp"
                android:checked="true"
                android:text="@string/thinking_mode_title"
                android:textColor="@color/ink"
                android:textSize="16sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/temperatureHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/temperatureTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/temperature_title"
                    android:textColor="@color/ink"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/temperatureValueText"
                    android:layout_width="56dp"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:text="0.0"
                    android:textColor="@color/clay"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <com.google.android.material.slider.Slider
                android:id="@+id/temperatureSlider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:stepSize="0.1"
                android:value="0.0"
                android:valueFrom="0.0"
                android:valueTo="2.0"
                app:haloColor="@color/mint"
                app:labelBehavior="gone"
                app:thumbColor="@color/clay"
                app:tickColor="@color/sage"
                app:trackColorActive="@color/clay"
                app:trackColorInactive="@color/soft_line" />

            <TextView
                android:id="@+id/temperatureHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/temperature_hint"
                android:textColor="@color/ink"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/temperatureThinkingMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/temperature_thinking_disabled_hint"
                android:textColor="@color/error_red"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
